# Email Configuration for Stdytime
# Copy this file to .env and fill in your SMTP settings

# SMTP Server Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Sender Email Credentials
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-specific-password

# Note for Gmail Users:
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Generate an "App Password" at https://myaccount.google.com/apppasswords
# 3. Use the 16-character password in SENDER_PASSWORD above
# 4. Do NOT use your regular Gmail password

# Alternative Email Providers:
# Outlook/Office365: smtp-mail.outlook.com, port 587
# Yahoo Mail: smtp.mail.yahoo.com, port 587 (requires app-specific password)
# SendGrid: smtp.sendgrid.net, port 587

# -----------------------------------------------------
# App Security / Deployment Settings
# -----------------------------------------------------
# Required in production (Render)
SECRET_KEY=replace-with-a-long-random-secret

# Set to production in hosted environments
APP_ENV=development

# HTTPS cookie security (true for Render production)
COOKIE_SECURE=false

# Secret used to verify machine-bound license keys.
# Keep this in sync with the key generation process used when issuing paid licenses.
STDYTIME_LICENSE_SECRET=replace-with-license-signing-secret

# Optional: database location override (e.g., /var/data/Stdytime.db on Render disk)
# DB_PATH=data/Stdytime.db

# Optional one-time admin bootstrap (leave blank after initial setup)
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=

# Optional operational toggles
# ENABLE_PUBLIC_EXIT_ROUTE=false
# ENABLE_VERSION_AUTOBUMP=true
# DEBUG_CACHE=false

