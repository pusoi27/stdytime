# ================================================================
#  New Live Dashboard API Routes (AJAX)
# ================================================================
active_students_cache = []
checked_out_cache = []
selected_assistants_cache = []


@app.route("/api/students/list")
def api_students_list():
    """Return all students with status information for AJAX refresh."""
    data = []
    for r in student_manager.get_all_students():
        # normalize tuple shapes
        if len(r) >= 8:
            sid, name, subj, lvl, email, phone, photo, active = r
        elif len(r) == 7:
            sid, name, subj, lvl, email, phone, photo = r
            # need to query DB for active flag
            active_row = sqlite3.connect(DB_PATH).execute("SELECT active FROM students WHERE id=?", (sid,)).fetchone()
            active = active_row[0] if active_row else 0
        else:
            # unexpected shape, skip
            continue
        if active != 1:
            continue
        status = "registered"
        if any(a.get("id") == sid for a in active_students_cache):
            status = "active"
        if any(ch.get("id") == sid for ch in checked_out_cache):
            status = "checked"
        # compute total time (seconds) for this student for today
        with sqlite3.connect(DB_PATH) as conn2:
            cur2 = conn2.cursor()
            cur2.execute(
                "SELECT COALESCE(SUM(duration),0) FROM sessions WHERE student_id=? AND DATE(start_time)=DATE('now')",
                (sid,)
            )
            total_secs_row = cur2.fetchone()
            total_secs = int(total_secs_row[0]) if total_secs_row and total_secs_row[0] is not None else 0

        data.append(dict(id=sid, name=name, subject=subj,
                         level=lvl, photo=photo, status=status, total_seconds=total_secs))
    return jsonify(data)


@app.route("/api/students/start/<int:sid>", methods=["POST"])
def api_student_start(sid):
    """Start a study session for this student (move to active)."""
    if any(a["id"] == sid for a in active_students_cache):
        return jsonify({"error": "Already active"}), 400

    timer_manager.start_session(sid)

    with sqlite3.connect(DB_PATH) as conn:
        c = conn.cursor()
        row = c.execute(
            "SELECT id,name,subject,level,photo FROM students WHERE id=?", (sid,)
        ).fetchone()
    if not row:
        return jsonify({"error": "Student not found"}), 404

    # row may include photo at index 4
    photo = row[4] if len(row) > 4 else None
    active_students_cache.append(
        dict(id=row[0], name=row[1], subject=row[2], level=row[3], photo=photo)
    )
    return jsonify({"success": True})


@app.route("/api/students/stop/<int:sid>", methods=["POST"])
def api_student_stop(sid):
    """Stop a study session for this student (move to checked out)."""
    result = timer_manager.stop_session(sid)
    if not result:
        return jsonify({"error": "No active session found"}), 400

    global active_students_cache, checked_out_cache
    active_students_cache = [s for s in active_students_cache if s["id"] != sid]

    with sqlite3.connect(DB_PATH) as conn:
        c = conn.cursor()
        row = c.execute(
            "SELECT id,name,subject,level,photo FROM students WHERE id=?", (sid,)
        ).fetchone()
    if not row:
        return jsonify({"error": "Student not found"}), 404

    photo = row[4] if len(row) > 4 else None
    checked_out_cache.append(
        dict(
            id=row[0],
            name=row[1],
            subject=row[2],
            level=row[3],
            photo=photo,
            duration=result["duration"],
        )
    )
    return jsonify({"success": True})

@app.route("/api/sessions/active")
def api_sessions_active():
    """Return active sessions with start_time for live timers."""
    result = []
    for s in active_students_cache:
        sid = s["id"]
        with sqlite3.connect(DB_PATH) as conn:
            cur = conn.cursor()
            cur.execute(
                "SELECT start_time FROM sessions WHERE student_id=? ORDER BY id DESC LIMIT 1",
                (sid,),
            )
            row = cur.fetchone()
            start_time = row[0] if row else None
        result.append({
            "id": sid,
            "name": s.get("name"),
            "subject": s.get("subject"),
            "level": s.get("level"),
            "photo": s.get("photo"),
            "start_time": start_time
        })
    return jsonify(result)


@app.route("/api/assistants/list")
def api_assistants_list():
    """Return all available assistants with duty status and start time for payroll."""
    assistants = assistant_manager.get_all_assistants()
    result = []
    for a in assistants:
        duty_info = next((x for x in selected_assistants_cache if x["id"] == a[0]), None)
        result.append(
            dict(
                id=a[0],
                name=a[1],
                role=a[2] if len(a) > 2 else "",
                email=a[3] if len(a) > 3 else "",
                phone=a[4] if len(a) > 4 else "",
                on_duty=duty_info is not None,
                start_time=duty_info["start_time"] if duty_info else None,
            )
        )
    return jsonify(result)


@app.route("/api/assistants/select/<int:aid>", methods=["POST"])
def api_assistants_select(aid):
    """Toggle assistant on/off duty with payroll time tracking."""
    global selected_assistants_cache
    from datetime import datetime
    
    assistant = assistant_manager.get_assistant(aid)
    if not assistant:
        return jsonify({"error": "Assistant not found"}), 404
    
    # Check if already on duty
    duty_info = next((a for a in selected_assistants_cache if a["id"] == aid), None)
    
    if duty_info:
        # End duty: calculate duration and persist to DB
        start = datetime.fromisoformat(duty_info.get("start_time")) if duty_info.get("start_time") else None
        end = datetime.now()
        duration = int((end - start).total_seconds()) if start else 0
        # persist to assistant_sessions table
        with sqlite3.connect(DB_PATH) as conn:
            cur = conn.cursor()
            cur.execute(
                "INSERT INTO assistant_sessions (assistant_id, start_time, end_time, duration) VALUES (?,?,?,?)",
                (aid, start.isoformat() if start else None, end.isoformat(), duration),
            )
            conn.commit()
        # remove from cache
        selected_assistants_cache = [a for a in selected_assistants_cache if a["id"] != aid]
        return jsonify({"success": True, "on_duty": False, "duration": duration})
    else:
        # Start duty: add to cache with start time
        selected_assistants_cache.append(
            dict(
                id=assistant[0],
                name=assistant[1],
                role=assistant[2] if len(assistant) > 2 else "",
                start_time=datetime.now().isoformat(),
            )
        )
        return jsonify({"success": True, "on_duty": True})


